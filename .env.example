# Copy this file to .env.local and fill in your AdSense ad-unit slot IDs
# (the 10-digit number AdSense gives you per ad unit, NOT the publisher id).
#
# The publisher id (ca-pub-XXXXXXXXXXXXXXXX) goes directly in index.html.
#
# 4 banners:
#   - 2 vertical 120×300 on the right side  (top + bottom)        — 2xl screens
#   - 2 horizontal 970×250 stacked below the stations grid        — md+ screens

VITE_ADSENSE_SLOT_RIGHT_TOP=
VITE_ADSENSE_SLOT_RIGHT_BOTTOM=
VITE_ADSENSE_SLOT_BOTTOM=
VITE_ADSENSE_SLOT_BOTTOM_2=
